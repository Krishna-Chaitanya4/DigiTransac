# DigiTransac Environment Variables
# Copy this file to .env and fill in the values
# These override the appsettings.json configuration

# =============================================================================
# REQUIRED FOR PRODUCTION
# =============================================================================

# JWT Secret Key (minimum 32 characters, used for signing tokens)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters

# Encryption KEK (Key Encryption Key for envelope encryption, Base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEK=your-base64-encoded-32-byte-key

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Gmail sender email address
EMAIL_SENDER=your-email@gmail.com

# Gmail App Password (generate at: https://myaccount.google.com/apppasswords)
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB connection string
# For local development: mongodb://localhost:27017
# For production: mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_CONNECTION_STRING=mongodb://localhost:27017

# Database name
MONGODB_DATABASE_NAME=DigiTransac

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# JWT token expiration (defaults shown)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting (defaults shown)
# RATE_LIMIT_PERMIT_LIMIT=100
# RATE_LIMIT_WINDOW_SECONDS=60

# Security settings
# SECURITY_USE_HTTPS=true
# SECURITY_USE_SECURE_COOKIES=true
# SECURITY_COOKIE_DOMAIN=
