{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { 
        "Name": "File", 
        "Args": { 
          "path": "logs/digitransac-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        } 
      }
    ],
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Application": "DigiTransac"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "DigiTransac",
    "MaxConnectionPoolSize": 100,
    "MinConnectionPoolSize": 10,
    "WaitQueueTimeoutSeconds": 30,
    "MaxConnectionIdleTimeSeconds": 600,
    "MaxConnectionLifeTimeSeconds": 1800,
    "ConnectTimeoutSeconds": 30,
    "SocketTimeoutSeconds": 0,
    "ServerSelectionTimeoutSeconds": 30,
    "RetryWrites": true,
    "RetryReads": true
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "DigiTransac",
    "Audience": "DigiTransac",
    "AccessTokenExpireMinutes": 15,
    "RefreshTokenExpireDays": 7
  },
  "Encryption": {
    "Key": "${ENCRYPTION_KEY}",
    "Kek": "${ENCRYPTION_KEK}",
    "Provider": "Local",
    "KeyVaultUrl": "",
    "KeyName": ""
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "${EMAIL_SENDER}",
    "SenderName": "DigiTransac",
    "AppPassword": "${EMAIL_APP_PASSWORD}"
  },
  "Security": {
    "UseHttps": true,
    "UseSecureCookies": true,
    "CookieDomain": ""
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 60,
    "SensitivePermitLimit": 5,
    "SensitiveWindowSeconds": 300,
    "UserPermitLimit": 200,
    "UserWindowSeconds": 60,
    "TransactionPermitLimit": 50,
    "TransactionWindowSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "DigiTransac.Api",
    "ServiceVersion": "1.0.0",
    "UseConsoleExporter": false,
    "OtlpEndpoint": "",
    "Region": "local"
  },
  "WebPush": {
    "PublicKey": "${VAPID_PUBLIC_KEY}",
    "PrivateKey": "${VAPID_PRIVATE_KEY}",
    "Subject": "mailto:${EMAIL_SENDER}"
  }
}
