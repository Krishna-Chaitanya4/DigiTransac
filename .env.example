# DigiTransac Environment Variables - Key Vault Architecture
# Copy this file to .env and fill in your actual values

# ===== Azure Key Vault (Required) =====
# All secrets (MongoDB connection, JWT secret, encryption key) are stored in Key Vault
AZURE_KEY_VAULT_URL=https://digitransac-kv-XXXX.vault.azure.net/

# ===== Database Configuration =====
MONGODB_DATABASE_NAME=DigiTransacDB

# ===== Server Configuration =====
PORT=5000
NODE_ENV=development

# ===== CORS & URLs =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ===== JWT Configuration =====
JWT_EXPIRE=7d

# ===== Frontend Configuration =====
VITE_API_URL=http://localhost:5000/api

# ===== Development Setup =====
# 1. Login to Azure: az login
# 2. Application will automatically fetch secrets from Key Vault
# 3. For production, Managed Identity is used (no login required)

# Security Notes:
# ✅ All secrets stored in Azure Key Vault
# ✅ Zero secrets in code or .env files
# ✅ Managed Identity for production
# ✅ Azure CLI for development

# - Store production secrets in Azure Key Vault
