# DigiTransac Environment Variables
# Copy this file to .env and fill in your actual values

# ===== Backend Configuration =====
# Cosmos DB Configuration
COSMOS_ENDPOINT=https://your-cosmosdb-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-db-primary-key-here
COSMOS_DATABASE_NAME=DigiTransacDB

# JWT Configuration
JWT_SECRET=your-jwt-secret-min-32-characters-recommended-64-chars-for-production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://192.168.0.11:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Encryption (Optional)
MASTER_ENCRYPTION_KEY=your-master-encryption-key-32-chars-or-more
KEY_VAULT_URL=

# Gmail Integration (Optional)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# ===== Frontend Configuration =====
# API URL (optional - auto-detected if not set)
VITE_API_URL=http://localhost:5000

# ===== Docker Configuration =====
# These are used by docker-compose.yml
# Make sure to set production values when deploying

# Example for local development with Cosmos DB Emulator:
# COSMOS_ENDPOINT=https://localhost:8081
# COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEclP9qNdxzYg==

# Example for Azure Cosmos DB:
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=<get-from-azure-portal>

# Security Notes:
# - Never commit this file to version control
# - JWT_SECRET should be at least 32 characters
# - Use different secrets for dev/staging/production
# - Store production secrets in Azure Key Vault
