# DigiTransac Backend - Key Vault Architecture

# ===== Azure Key Vault (Required) =====
AZURE_KEY_VAULT_URL=https://digitransac-kv-XXXX.vault.azure.net/

# ===== Database Configuration =====
MONGODB_DATABASE_NAME=DigiTransacDB

# ===== Server Configuration =====
PORT=5000
NODE_ENV=development

# ===== CORS & URLs =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ===== JWT Configuration =====
JWT_EXPIRE=7d

# ===== Gmail OAuth (Optional) =====
# Get from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret

# ===== Key Vault Secrets =====
# These are fetched automatically from Azure Key Vault:
# - MongoDB-ConnectionString: Full DocumentDB connection string
# - JWT-Secret: JWT token signing key
# - Master-Encryption-Key: Data encryption key

# Development: Run 'az login' first
# Production: Uses Managed Identity automatically

